@@ -1,17 +1,46 @@
 package com.sharkkernel.manager.data
 
 import android.os.Build
+import android.os.SystemClock
 import com.sharkkernel.manager.core.RootShell
 import com.sharkkernel.manager.model.DeviceState
 
 object DeviceRepository {
     @Volatile private var cached: DeviceState? = null
+    @Volatile private var cachedAtMs: Long = 0L
+
     suspend fun read(): DeviceState {
-        cached?.let { return it }
-        val root = RootShell.granted()
-        val probe = RootShell.exec("[ -d /sys/kernel/shark_g3d_oc ] || [ -d /sys/kernel/debug/shark_soc ] || [ -d /sys/kernel/fvmap_interface ]")
+        val now = SystemClock.elapsedRealtime()
+        cached?.let { state ->
+            val ttl = if (state.root) 30_000L else 1_500L
+            if (now - cachedAtMs < ttl) return state
+        }
+
+        val rootProbe = RootShell.probe()
+        val probe = if (rootProbe.granted) {
+            RootShell.exec("[ -d /sys/kernel/shark_g3d_oc ] || [ -d /sys/kernel/debug/shark_soc ] || [ -d /sys/kernel/fvmap_interface ]")
+        } else null
         val deviceOk = Build.MODEL.startsWith("SM-S721", true) || Build.DEVICE.equals("r12s", true)
         val socOk = Build.BOARD.equals("s5e9945", true) || Build.HARDWARE.equals("s5e9945", true)
-        return DeviceState(root, root && deviceOk && socOk && probe.ok, Build.MODEL, Build.DEVICE, Build.HARDWARE, System.getProperty("os.version").orEmpty()).also { cached = it }
+        return DeviceState(
+            root = rootProbe.granted,
+            rootDetail = rootProbe.detail,
+            supported = rootProbe.granted && deviceOk && socOk && probe?.ok == true,
+            model = Build.MODEL,
+            device = Build.DEVICE,
+            hardware = Build.HARDWARE,
+            kernel = System.getProperty("os.version").orEmpty()
+        ).also {
+            cached = it
+            cachedAtMs = now
+        }
+    }
+
+    fun invalidateRoot() {
+        cached = null
+        cachedAtMs = 0L
+        RootShell.reset()
     }
 }
